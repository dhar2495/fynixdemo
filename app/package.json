{
  "name": "SyslaFynix-finance-app",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "description": "SyslaFynix cross-platform app (Android + iOS + Web) built with Expo.",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~3.2.3",
    "@gorhom/bottom-sheet": "^4.6.4",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.28",
    "expo-blur": "~13.0.3",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.10",
    "expo-linear-gradient": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "lucide-react-native": "^1.23.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
